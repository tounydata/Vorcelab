# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
# Optionnel côté frontend : surcharge le projet visé par l'app (défaut : prod)
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-anon-key>
# Server-only — never expose in browser
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Strava OAuth ──────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=<your-strava-client-id>
STRAVA_CLIENT_SECRET=<your-strava-client-secret>
STRAVA_REDIRECT_URI=https://<your-domain>/auth/strava/callback
# Webhook subscription verification token (you choose this value)
STRAVA_VERIFY_TOKEN=<your-random-verify-token>
# Webhook push signing secret (from Strava API settings)
STRAVA_WEBHOOK_SIGNING_SECRET=<your-webhook-signing-secret>

# ── Stripe (monétisation PRO) ─────────────────────────────────────────────────
# Payment Links (Stripe Dashboard → Payment Links) — injectés au build.
# Ajouter metadata plan=monthly / plan=annual sur chaque lien (lu par le webhook).
# ⚠️ À déclarer aussi en secrets GitHub Actions (deploy-pages.yml).
VITE_STRIPE_MONTHLY_URL=<your-stripe-monthly-payment-link>
VITE_STRIPE_ANNUAL_URL=<your-stripe-annual-payment-link>
# Server-only (Supabase Secrets) — signature du webhook stripe-webhook
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-signing-secret>

# ── Claude / AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Fond de carte (stratégie de course) ───────────────────────────────────────
# Optionnel : relief ombré derrière le tracé GPS (tuiles raster assemblées au pixel).
# Sans clé → fond sombre uni (repli). NB : on utilise les tuiles /tiles (gratuites),
# pas l'API Static Maps (payante).
# MapTiler (recommandé, free tier généreux) — tileset relief par défaut : "hillshade".
VITE_MAPTILER_KEY=<your-maptiler-key>
# VITE_MAPTILER_TILESET=hillshade      # ex. satellite-v2, terrain-rgb-v2 (tilesets raster)
# Alternative Mapbox (si pas de MapTiler) :
# VITE_MAPBOX_TOKEN=<your-mapbox-token>
# VITE_MAPBOX_STYLE=dark-v11           # ex. outdoors-v12, satellite-v9

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
